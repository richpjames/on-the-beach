// Copy this file to `Secrets.xcconfig` (same directory) and fill in the real
// value. `Secrets.xcconfig` is gitignored so the key never lands in the repo.
//
// In Xcode, set this file as the Configuration File for the ShareExtension
// target (Project ▸ Info ▸ Configurations), or `#include` it from the target's
// build configuration. The value flows into the extension's Info.plist via the
// `$(OTB_INGEST_API_KEY)` substitution.
//
// It must match INGEST_API_KEY in the server's environment.

OTB_INGEST_API_KEY = replace-with-your-ingest-api-key
