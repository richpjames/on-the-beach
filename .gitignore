# scripts/generate-brand-assets.sh turns into every favicon and app icon.
!assets/logo.png

uploads

# SvelteKit
.svelte-kit/
build/

# iOS / Capacitor native shell
# The entire ios/ project is generated by `cap add ios` on a mac and is not
# committed. Hand-authored native sources live in native/ and are referenced
# into the generated Xcode project by path.
ios/
native/ShareExtension/Secrets.xcconfig
*.ipa
Pods/
