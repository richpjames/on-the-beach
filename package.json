{
  "name": "on-the-beach",
  "version": "1.0.176",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite dev",
    "build": "bunx --bun vite build",
    "preview": "bun run build && bun build/index.js",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "bun test tests/unit",
    "test:unit": "bun test tests/unit",
    "test:unit:watch": "bun test --watch tests/unit",
    "test:e2e": "bunx playwright test playwright",
    "test:ingest:prod": "bun test tests/e2e/ingest-prod.test.ts",
    "test:visual": "bunx playwright test --project=visual-desktop --project=visual-mobile --workers=1",
    "test:visual:update": "bunx playwright test --project=visual-desktop --project=visual-mobile --workers=1 --update-snapshots=all",
    "test:visual:update-baselines": "bash scripts/update-visual-baselines.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun server/db/seed.ts",
    "db:prod": "bun scripts/db-prod.ts",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "devcontainer": "devcontainer up --workspace-folder .",
    "devcontainer:ssh": "container_id=$(bun run devcontainer | sed -n 's/.*\"containerId\":\"\\([^\"]*\\)\".*/\\1/p' | tail -n1) && [ -n \"$container_id\" ] && docker exec -it \"$container_id\" bash",
    "eval:submit": "bun eval/submit.ts",
    "eval:status": "bun eval/status.ts",
    "eval:results": "bun eval/results.ts",
    "prepare": "husky",
    "start": "bun build/index.js",
    "cap:add": "cap add ios",
    "cap:sync": "cap sync ios",
    "cap:open": "cap open ios",
    "mac:bootstrap": "bash scripts/bootstrap-mac.sh",
    "mac": "bash scripts/build-mac.sh",
    "mac:install": "bash scripts/build-mac.sh --install",
    "mac:local": "OTB_APP_URL=http://localhost:3000 bash scripts/build-mac.sh --install",
    "ios": "bash scripts/build-ios.sh",
    "brand:assets": "bash scripts/generate-brand-assets.sh"
  },
  "dependencies": {
    "@mistralai/mistralai": "^1.14.1",
    "case": "^1.6.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "sortablejs": "^1.15.7",
    "xstate": "^5.28.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6",
    "@capacitor/core": "^6",
    "@capacitor/ios": "^6",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.69.0",
    "@sveltejs/vite-plugin-svelte": "^6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@types/sortablejs": "^1.15.9",
    "better-sqlite3": "^12.6.2",
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.51.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^5.9.3",
    "vite": "^7"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "bun --bun x oxlint",
      "bun --bun x oxfmt --write --no-error-on-unmatched-pattern"
    ]
  }
}
