{
  "name": "on-the-beach",
  "version": "1.0.113",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/unit",
    "test:unit": "bun test tests/unit",
    "test:unit:watch": "bun test --watch tests/unit",
    "test:e2e": "bunx playwright test playwright",
    "test:visual": "bunx playwright test --project=visual-desktop --project=visual-mobile --workers=1",
    "test:visual:update": "bunx playwright test --project=visual-desktop --project=visual-mobile --workers=1 --update-snapshots=all",
    "test:visual:update-baselines": "bash scripts/update-visual-baselines.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun server/db/seed.ts",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "devcontainer": "devcontainer up --workspace-folder .",
    "devcontainer:ssh": "container_id=$(bun run devcontainer | sed -n 's/.*\"containerId\":\"\\([^\"]*\\)\".*/\\1/p' | tail -n1) && [ -n \"$container_id\" ] && docker exec -it \"$container_id\" bash",
    "eval:submit": "bun eval/submit.ts",
    "eval:status": "bun eval/status.ts",
    "eval:results": "bun eval/results.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@mistralai/mistralai": "^1.14.1",
    "case": "^1.6.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "sortablejs": "^1.15.7",
    "xstate": "^5.28.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@types/sortablejs": "^1.15.9",
    "better-sqlite3": "^12.6.2",
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "bun --bun x oxlint",
      "bun --bun x oxfmt --write --no-error-on-unmatched-pattern"
    ]
  }
}
